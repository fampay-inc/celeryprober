{
  "probes": [
    {
      "name": "payment-service",
      "enabled": true,
      "description": "Monitors Celery tasks for the payment service",
      "celery_redis_broker_url": "redis://localhost:6379/0",
      "stale_task_set_key": "payment_stale_tasks",
      "stale_task_callback_context_timeout_sec": 5,
      "stale_task_callback_delay_duration_min": 15,
      "blacklisted_task_names": ["periodic_task", "cleanup_task"]
    },
    {
      "name": "order-service",
      "enabled": true,
      "description": "Monitors Celery tasks for the order service",
      "celery_redis_broker_url": "redis://localhost:6379/1",
      "stale_task_set_key": "order_stale_tasks",
      "stale_task_callback_context_timeout_sec": 5,
      "stale_task_callback_delay_duration_min": 15,
      "blacklisted_task_names": []
    },
    {
      "name": "notification-service",
      "enabled": true,
      "description": "Monitors Celery tasks for the notification service",
      "celery_redis_broker_url": "redis://localhost:6379/2",
      "stale_task_set_key": "notification_stale_tasks",
      "stale_task_callback_context_timeout_sec": 5,
      "stale_task_callback_delay_duration_min": 10,
      "blacklisted_task_names": ["periodic_notification"]
    }
  ]
}
