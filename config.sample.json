{
  "probes": [
    {
      "name": "bran-prod",
      "enabled": true,
      "description": "Monitors Celery tasks for the bran service",
      "celery_redis_broker_url": "redis://localhost:6379/0",
      "stale_task_set_key": "bran_stale_tasks",
      "stale_task_callback_context_timeout_sec": 5,
      "stale_task_callback_delay_duration_min": 15
    },
    {
      "name": "hodor-prod",
      "enabled": true,
      "description": "Monitors Celery tasks for the hodor service",
      "celery_redis_broker_url": "redis://localhost:6379/1",
      "stale_task_set_key": "hodor_stale_tasks",
      "stale_task_callback_context_timeout_sec": 5,
      "stale_task_callback_delay_duration_min": 15,
      "blacklisted_task_names": [
        "test_task",
        "dont_alert_on_this_task"
      ]
    }
  ]
}
