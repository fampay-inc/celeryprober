{
  "probes": [
    {
      "name": "westeros-prod",
      "enabled": true,
      "description": "Monitors Celery tasks for the westeros service",
      "celery_redis_broker_url": "redis://localhost:6379/0",
      "stale_task_set_key": "westeros_stale_tasks",
      "stale_task_callback_context_timeout_sec": 5,
      "stale_task_callback_delay_duration_min": 15
    },
    {
      "name": "ironbank-prod",
      "enabled": true,
      "description": "Monitors Celery tasks for the ironbank service",
      "celery_redis_broker_url": "redis://localhost:6379/1",
      "stale_task_set_key": "ironbank_stale_tasks",
      "stale_task_callback_context_timeout_sec": 5,
      "stale_task_callback_delay_duration_min": 15,
      "blacklisted_task_names": ["upi_debit_ingestion_slave", "check_billpayment_order_status"]
    }
  ]
}
